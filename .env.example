# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Default Telegram chat ID (used when no chatId is specified per reminder)
# Get your chat_id by messaging @userinfobot on Telegram
TELEGRAM_DEFAULT_CHAT_ID=your_chat_id_here

# Dashboard login password (leave empty to disable authentication)
DASHBOARD_PASSWORD=yourpassword

# SQLite database file path (relative to project root)
DATABASE_PATH=./data/reminders.db

# Dashboard login password (leave empty to disable authentication)
DASHBOARD_PASSWORD=your_password_here

# App port (optional)
PORT=3000
