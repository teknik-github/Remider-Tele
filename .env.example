# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Default Telegram chat ID (used when no chatId is specified per reminder)
# Get your chat_id by messaging @userinfobot on Telegram
TELEGRAM_DEFAULT_CHAT_ID=your_chat_id_here

# Dashboard login password (leave empty to disable authentication)
DASHBOARD_PASSWORD=yourpassword

# Public URL of this app — used by the Telegram /web command to generate magic links
# e.g. http://localhost:3000 for local dev, or https://yourdomain.com in production
APP_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# DB_TYPE: sqlite (default), mysql, or mariadb
DB_TYPE=sqlite

# SQLite — path to database file (only used when DB_TYPE=sqlite)
DATABASE_PATH=./data/reminders.db

# MySQL / MariaDB — connection details (only used when DB_TYPE=mysql or mariadb)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=secret
# DB_NAME=remindertele

# API key for POST /api/generate (generate a magic login URL programmatically)
# Use a long random string — e.g. openssl rand -hex 32
API_KEY=your_api_key_here

# App port (optional)
PORT=3000
